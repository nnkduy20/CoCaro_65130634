<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 🔥 BÀN CỜ (50% màn hình) -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="20"
        android:rowCount="20"
        android:background="#222222"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CYBER XO"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#00F5FF"
        android:gravity="center"
        android:padding="10dp"/>

    <!-- 🔥 KHU NÚT (50% màn hình) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#111111"
        android:padding="20dp">

        <Button
            android:id="@+id/btnPVP"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="PLAYER vs PLAYER"
            android:textColor="#00F5FF"
            android:textStyle="bold"
            android:background="@drawable/btn_neon"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnPVE"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="PLAYER vs AI"
            android:textColor="#FF1744"
            android:textStyle="bold"
            android:background="@drawable/btn_neon"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="RESET GAME"
            android:textColor="#00E676"
            android:textStyle="bold"
            android:background="@drawable/btn_neon"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="HISTORY"
            android:textColor="#D500F9"
            android:textStyle="bold"
            android:background="@drawable/btn_neon"
            android:layout_margin="10dp"/>

    </LinearLayout>

</LinearLayout>