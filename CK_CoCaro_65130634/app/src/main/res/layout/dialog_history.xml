<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="420dp"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="@drawable/neon_history_bg">

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvTitleHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📜 HISTORY LOG"
        android:textColor="#00F5FF"
        android:textStyle="bold"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="8dp"
        android:shadowColor="#00F5FF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="12"/>

    <!-- CONTENT -->
    <TextView
        android:id="@+id/tvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="10dp"
        android:background="#1A000000"
        android:scrollbars="vertical" />

    <!-- BUTTON -->
    <Button
        android:id="@+id/btnCloseHistory"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="CLOSE"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/neon_button"
        android:layout_marginTop="10dp"/>
</LinearLayout>